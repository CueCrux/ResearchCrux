{
  "name": "crown-verify",
  "version": "0.1.0",
  "description": "Standalone CROWN receipt chain verifier — no CueCrux dependencies",
  "type": "module",
  "license": "CC-BY-4.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "crown-verify": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "tsx src/__tests__/verify.test.ts",
    "verify": "tsx src/cli.ts"
  },
  "dependencies": {
    "@noble/curves": "^1.8.0",
    "@noble/hashes": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
